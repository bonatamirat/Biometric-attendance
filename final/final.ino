      return false;
    }
  }
  if (p != FINGERPRINT_OK) {
    Serial.println("Image timeout");
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Timeout"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return false;
  }

  p = finger.image2Tz();
