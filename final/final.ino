void setup() {
  Serial.begin(9600);
  delay(100);

  // Initialize OLED
  Wire.begin(OLED_SDA, OLED_SCL);
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    for (;;);
  }
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.println(F("Biometric"));
  display.drawBitmap(32, 16, FinPr_start_bits, FinPr_start_width, FinPr_start_height, SSD1306_WHITE); // Fingerprint icon
  display.display();
  delay(2000);

  // Connect to Wi-Fi
  WiFi.begin(ssid, password);
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.println(F("WiFi..."));
  display.drawBitmap(37, 15, Wifi_start_bits, Wifi_start_width, Wifi_start_height, SSD1306_WHITE); // Wi-Fi start icon
  display.display();
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected: " + WiFi.localIP().toString());
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.println(F("WiFi OK"));
  display.setTextSize(1);
  display.println(WiFi.localIP());
  display.drawBitmap(32, 15, Wifi_connected_bits, Wifi_connected_width, Wifi_connected_height, SSD1306_WHITE); // Wi-Fi connected icon
  display.display();
  delay(2000);

  // Initialize NTP client
  timeClient.begin();
  timeClient.update();
  Serial.println("Time: " + timeClient.getFormattedTime());

  // Initialize fingerprint sensor
  finger.begin(57600);
  if (finger.verifyPassword()) {
    Serial.println("Found fingerprint sensor!");
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Sensor OK"));
    display.drawBitmap(32, 16, FinPr_valid_bits, FinPr_valid_width, FinPr_valid_height, SSD1306_WHITE); // Valid icon
    display.display();
  } else {
    Serial.println("Did not find fingerprint sensor :(");
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Sensor Err"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    while (1) { delay(1); }
  }

  // Set up HTTP server routes
  server.on("/control", HTTP_POST, handleControl);
  server.on("/test", HTTP_GET, []() {
    Serial.println("Test endpoint called");
    server.send(200, "text/plain", "Test OK");
  });
  server.begin();
  Serial.println("HTTP server started");
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.println(F("Server OK"));
  display.drawBitmap(32, 16, FinPr_valid_bits, FinPr_valid_width, FinPr_valid_height, SSD1306_WHITE); // Valid icon
  display.display();
}

void loop() {
  server.handleClient();
  timeClient.update();
  static unsigned long lastCheck = 0;
  if (millis() - lastCheck > 5000) {
    if (finger.verifyPassword()) {
      Serial.println("Sensor OK");
    } else {
      Serial.println("Sensor disconnected");
    }
    lastCheck = millis();
  }
}

void handleControl() {
  Serial.println("Control endpoint called");
  String action = server.arg("action");
  String response;

  if (action == "enroll") {
    String name = server.arg("name");
    uint8_t id = server.arg("fingerprint_id").toInt();
    Serial.println("Enroll request: Name=" + name + ", ID=" + String(id));
    if (id > 0 && id <= 127 && name != "") {
      String enrollResult = enrollFingerprint(id);
      if (enrollResult == "success") {
        response = "{\"status\":\"success\",\"message\":\"Enrolled ID #" + String(id) + "\"}";
      } else {
        response = "{\"status\":\"error\",\"message\":\"Enrollment failed: " + enrollResult + "\"}";
      }
    } else {
      response = "{\"status\":\"error\",\"message\":\"Invalid data\"}";
    }
  } else if (action == "attendance") {
    Serial.println("Attendance request");
    if (markAttendance()) {
      response = "{\"status\":\"success\",\"message\":\"" + String(finger.fingerID) + "\"}";
    } else {
      response = "{\"status\":\"error\",\"message\":\"Fingerprint not found\"}";
    }
  } else if (action == "delete") {
    uint8_t id = server.arg("fingerprint_id").toInt();
    Serial.println("Delete request: ID=" + String(id));
    if (id > 0 && id <= 127) {
      if (deleteFingerprint(id)) {
        response = "{\"status\":\"success\",\"message\":\"Deleted ID #" + String(id) + "\"}";
      } else {
        response = "{\"status\":\"error\",\"message\":\"Deletion failed\"}";
      }
    } else {
      response = "{\"status\":\"error\",\"message\":\"Invalid ID\"}";
    }
  } else {
    response = "{\"status\":\"error\",\"message\":\"Invalid action\"}";
  }
  server.send(200, "application/json", response);
}

