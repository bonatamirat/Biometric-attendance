  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.print(F("Enroll #"));
  display.println(id);
  display.drawBitmap(32, 16, FinPr_scan_bits, FinPr_scan_width, FinPr_scan_height, SSD1306_WHITE); // Scan icon
  display.display();

  int p = -1;
  Serial.println("Place finger...");
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.println(F("Place Finger"));
  display.drawBitmap(32, 16, FinPr_start_bits, FinPr_start_width, FinPr_start_height, SSD1306_WHITE); // Start icon
  display.display();
  unsigned long startTime = millis();
  while (p != FINGERPRINT_OK && millis() - startTime < 60000) {
    p = finger.getImage();
    if (p == FINGERPRINT_OK) {
      Serial.println("Image taken");
      display.clearDisplay();
      display.setTextSize(2); // Bold text
      display.setCursor(0, 0);
      display.println(F("Image OK"));
      display.drawBitmap(32, 16, FinPr_valid_bits, FinPr_valid_width, FinPr_valid_height, SSD1306_WHITE); // Valid icon
      display.display();
    } else if (p == FINGERPRINT_NOFINGER) {
      delay(100);
    } else {
      Serial.println("Image error: " + String(p));
      display.clearDisplay();
      display.setTextSize(2); // Bold text
      display.setCursor(0, 0);
      display.println(F("Image Err"));
      display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
      display.display();
      return "Image error " + String(p);
    }
  }
  if (p != FINGERPRINT_OK) {
    Serial.println("Image timeout");
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Timeout"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return "Image timeout";
  }

  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) {
    Serial.println("Conversion error: " + String(p));
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Conv Err"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return "Conversion error " + String(p);
  }

  Serial.println("Remove finger");
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.println(F("Remove"));
  display.drawBitmap(32, 16, FinPr_start_bits, FinPr_start_width, FinPr_start_height, SSD1306_WHITE); // Start icon
  display.display();
  delay(2000);
  p = 0;
  while (p != FINGERPRINT_NOFINGER && millis() - startTime < 60000) {
    p = finger.getImage();
  }

  Serial.println("Place same finger again");
  display.clearDisplay();
  display.setTextSize(2); // Bold text
  display.setCursor(0, 0);
  display.println(F("Place Again"));
  display.drawBitmap(32, 16, FinPr_start_bits, FinPr_start_width, FinPr_start_height, SSD1306_WHITE); // Start icon
  display.display();
  p = -1;
  while (p != FINGERPRINT_OK && millis() - startTime < 60000) {
    p = finger.getImage();
    if (p == FINGERPRINT_OK) {
      Serial.println("Image taken");
      display.clearDisplay();
      display.setTextSize(2); // Bold text
      display.setCursor(0, 0);
      display.println(F("Image OK"));
      display.drawBitmap(32, 16, FinPr_valid_bits, FinPr_valid_width, FinPr_valid_height, SSD1306_WHITE); // Valid icon
      display.display();
    } else if (p == FINGERPRINT_NOFINGER) {
      delay(100);
    } else {
      Serial.println("Second image error: " + String(p));
      display.clearDisplay();
      display.setTextSize(2); // Bold text
      display.setCursor(0, 0);
      display.println(F("Image Err"));
      display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
      display.display();
      return "Second image error " + String(p);
    }
  }
  if (p != FINGERPRINT_OK) {
    Serial.println("Second image timeout");
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Timeout"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return "Second image timeout";
  }

  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) {
    Serial.println("Second conversion error: " + String(p));
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Conv Err"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return "Second conversion error " + String(p);
  }

  p = finger.createModel();
  if (p != FINGERPRINT_OK) {
    Serial.println("Model error: " + String(p));
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Model Err"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return "Model error " + String(p);
  }

  p = finger.storeModel(id);
  if (p == FINGERPRINT_OK) {
    Serial.println("Stored ID #" + String(id));
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.print(F("Stored #"));
    display.println(id);
    display.drawBitmap(32, 16, FinPr_valid_bits, FinPr_valid_width, FinPr_valid_height, SSD1306_WHITE); // Valid icon
    display.display();
    return "success";
  } else {
    Serial.println("Storage error: " + String(p));
    display.clearDisplay();
    display.setTextSize(2); // Bold text
    display.setCursor(0, 0);
    display.println(F("Store Err"));
    display.drawBitmap(32, 16, FinPr_failed_bits, FinPr_failed_width, FinPr_failed_height, SSD1306_WHITE); // Failed icon
    display.display();
    return "Storage error " + String(p);
  }
}

