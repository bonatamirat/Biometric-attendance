  display.setCursor(0, 0);
  display.println(F("Place Finger"));
  display.drawBitmap(32, 16, FinPr_start_bits, FinPr_start_width, FinPr_start_height, SSD1306_WHITE); // Start icon
  display.display();

  int p = -1;
  unsigned long startTime = millis();
  while (p != FINGERPRINT_OK && millis() - startTime < 60000) {
    p = finger.getImage();
    if (p == FINGERPRINT_OK) {
      Serial.println("Image taken");
      display.clearDisplay();
      display.setTextSize(2); // Bold text
      display.setCursor(0, 0);
